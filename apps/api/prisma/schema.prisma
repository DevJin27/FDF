datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String    @id @default(cuid())
  phone       String    @unique
  name        String?
  upiId       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sessions    Session[] @relation("SessionLeader")
  memberships Member[]
  orders      Order[]   @relation("OrderLeader")
  streak      Streak?
}

model Session {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  leaderId    String
  leader      User          @relation("SessionLeader", fields: [leaderId], references: [id])
  platform    Platform
  minOrder    Decimal       @db.Decimal(10, 2)
  deadline    DateTime
  status      SessionStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  members     Member[]
  cartItems   CartItem[]
  settlements Settlement[]
  orders      Order[]

  @@index([leaderId])
  @@index([platform])
  @@index([status])
}

model Member {
  id          String       @id @default(cuid())
  sessionId   String
  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime     @default(now())
  cartItems   CartItem[]
  orderItems  OrderItem[]
  settlements Settlement[]

  @@unique([sessionId, userId])
  @@index([userId])
}

model Item {
  id          String      @id @default(cuid())
  platform    Platform
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([platform, active])
}

model CartItem {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  itemId    String?
  item      Item?    @relation(fields: [itemId], references: [id])
  name      String
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([memberId])
}

model Order {
  id          String      @id @default(cuid())
  sessionId   String
  session     Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  leaderId    String
  leader      User        @relation("OrderLeader", fields: [leaderId], references: [id])
  status      OrderStatus @default(CREATED)
  subtotal    Decimal     @db.Decimal(10, 2)
  paidAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
  settlements Settlement[]

  @@unique([sessionId])
  @@index([leaderId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  itemId    String?
  item      Item?    @relation(fields: [itemId], references: [id])
  name      String
  price     Decimal  @db.Decimal(10, 2)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([memberId])
}

model Settlement {
  id         String    @id @default(cuid())
  sessionId  String
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  orderId    String?
  order      Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  memberId   String
  member     Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amountOwed Decimal   @db.Decimal(10, 2)
  paid       Boolean   @default(false)
  paidAt     DateTime?

  @@unique([sessionId, memberId])
  @@unique([orderId, memberId])
  @@index([orderId])
  @@index([memberId])
}

model Streak {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  count           Int       @default(0)
  lastCompletedAt DateTime?
  badgeExpiresAt  DateTime?
}

enum Platform {
  BLINKIT
  SWIGGY
  ZEPTO
}

enum SessionStatus {
  OPEN
  LOCKED
  SETTLED
}

enum OrderStatus {
  CREATED
  PAID
  CANCELLED
}
