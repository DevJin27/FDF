# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host.neon.tech/fdf?sslmode=require

# ── API Server (apps/api) ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── JWT Session ────────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-a-64-char-random-hex-string
SESSION_MAX_AGE_SECONDS=604800

# ── MSG91 OTP Provider ─────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=FDFAPP
MSG91_DLT_TE_ID=your-dlt-template-id
MSG91_OTP_MESSAGE_TEMPLATE=<#> Your FDF OTP is {otp}. It expires in 5 minutes.

# ── Next.js Web App (apps/web) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
